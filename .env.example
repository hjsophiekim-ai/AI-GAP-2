KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=12345678-01
KIS_PRODUCT_CODE=01
KIS_USE_PAPER=true

# ── 미국 시장 데이터(MU/NVDA/AMD/AVGO/QQQ) 다중 소스 수집 (선택) ─────────────
# 우선순위: Alpaca -> Polygon -> Finnhub -> yfinance(백업/전일 확인용) -> 네이버(최후 보조)
# 키가 없으면 해당 소스는 자동으로 건너뛰고 다음 fallback으로 넘어간다.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_DATA_FEED=iex
POLYGON_API_KEY=
FINNHUB_API_KEY=
ENABLE_ALPACA_US_DATA=true
ENABLE_POLYGON_US_DATA=false
ENABLE_FINNHUB_US_DATA=false
# yfinance/네이버는 항상 최후 fallback으로 사용 가능하지만, 완전히 끄고 싶을 때만 false로 설정
ENABLE_YFINANCE_FALLBACK=true
ENABLE_NAVER_US_FALLBACK=true
