# ── Runtime artifacts from local dev/test runs (2026-07-16) ─────────────────
# These are regenerated by running the app/tests locally and should never be
# committed. Already-tracked cache/state fixtures (e.g. data/cache/hynix_current.json,
# data/state/hynix_auto_state_mock.json) are intentionally left tracked and will
# still show as modified after a local run -- .gitignore cannot silence dirty
# diffs on files git already tracks, only prevent new untracked ones from
# recurring below.
.pytest_tmp_run/
.pytest_tmp_readiness/
.tmp_pytest/
nul
start_streamlit_*.ps1
start_streamlit_*.cmd
streamlit_*.log
streamlit_*_stdout.log
streamlit_*_stderr.log
streamlit_*_combined.log

# Untracked local cache/state artifacts (dated snapshots, locks, heartbeats,
# tick logs) generated by running the app locally -- distinct from the
# tracked fixture files already committed in these same directories.
data/cache/hynix_long_current.json
data/cache/us_sector_strength_*.json
data/cache/yfinance/
data/state/.hynix_auto_state_mock.lock
data/state/hynix_auto_state_real.json
data/state/hynix_daily_equity_*.json
data/state/intraday_auto_trade_state_*.json
data/state/master_pullback_top3_multi_entry_*.json
data/state/scheduler_heartbeat.json
data/state/market_ticks/
